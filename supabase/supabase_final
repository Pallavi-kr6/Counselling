-- 1. SYSTEM CONFIG & AUTH
CREATE TABLE IF NOT EXISTS public.users (
    id UUID PRIMARY KEY REFERENCES auth.users(id),
    email TEXT UNIQUE,
    user_type TEXT DEFAULT 'student', -- 'student', 'counsellor', 'admin'
    is_anonymous BOOLEAN DEFAULT false,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- 2. PROFILES
CREATE TABLE IF NOT EXISTS public.student_profiles (
    user_id UUID PRIMARY KEY REFERENCES public.users(id),
    name TEXT,
    year TEXT,
    course TEXT,
    gender TEXT,
    contact_info TEXT,
    department TEXT,
    created_at TIMESTAMPTZ DEFAULT now()
);

CREATE TABLE IF NOT EXISTS public.counsellor_profiles (
    user_id UUID PRIMARY KEY REFERENCES public.users(id),
    name TEXT,
    designation TEXT,
    teacher_id TEXT UNIQUE,
    gmail TEXT,
    room_no TEXT,
    phone_no TEXT,
    department TEXT,
    is_available BOOLEAN DEFAULT true,
    is_online BOOLEAN DEFAULT true,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- 3. APPOINTMENTS & SLOTS
CREATE TABLE IF NOT EXISTS public.appointments (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    student_id UUID REFERENCES public.users(id),
    counsellor_id UUID REFERENCES public.users(id),
    day_order_id TEXT,
    date DATE,
    start_time TIME,
    end_time TIME,
    status TEXT DEFAULT 'pending', -- 'pending', 'completed', 'cancelled'
    notes TEXT,
    start_datetime TIMESTAMPTZ,
    end_datetime TIMESTAMPTZ,
    completed_at TIMESTAMPTZ,
    followup_at TIMESTAMPTZ,
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now()
);

CREATE TABLE IF NOT EXISTS public.counsellor_availability (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    counsellor_id UUID REFERENCES public.users(id),
    day_order_id INTEGER,
    start_time TIME,
    end_time TIME,
    is_available BOOLEAN DEFAULT true
);

-- 4. MOOD & ANALYTICS
CREATE TABLE IF NOT EXISTS public.mood_tracking (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES public.users(id),
    mood INTEGER, -- 1-5 scale
    emoji TEXT,
    notes TEXT,
    stress_level INTEGER,
    sleep_hours DECIMAL,
    date DATE DEFAULT CURRENT_DATE,
    created_at TIMESTAMPTZ DEFAULT now()
);

CREATE TABLE IF NOT EXISTS public.mood_logs (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES public.users(id),
    session_id UUID,
    mood_score INTEGER, -- 1-10 scale
    label TEXT, -- 'positive', 'neutral', 'distressed', 'crisis'
    created_at TIMESTAMPTZ DEFAULT now()
);

-- 5. RESOURCES & CONTENT
CREATE TABLE IF NOT EXISTS public.resources (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    title TEXT,
    description TEXT,
    category TEXT,
    url TEXT,
    type TEXT, -- 'video', 'article', 'pdf'
    created_at TIMESTAMPTZ DEFAULT now()
);

-- 6. CHAT & SESSIONS
CREATE TABLE IF NOT EXISTS public.sessions (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES public.users(id),
    messages JSONB DEFAULT '[]',
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now()
);

-- 7. SAFETY & CRISIS (The features you requested)
CREATE TABLE IF NOT EXISTS public.crisis_alerts (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    student_id UUID REFERENCES public.users(id),
    student_email TEXT,
    message_snippet TEXT,
    keywords_matched TEXT[],
    assigned_counsellor_id UUID REFERENCES public.users(id),
    assigned_counsellor_name TEXT,
    severity TEXT DEFAULT 'HIGH',
    notification_sent BOOLEAN DEFAULT false,
    resolved BOOLEAN DEFAULT false,
    created_at TIMESTAMPTZ DEFAULT now()
);

CREATE TABLE IF NOT EXISTS public.student_watch_flags (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    student_id UUID REFERENCES public.users(id),
    tag TEXT DEFAULT 'watch',
    reason TEXT,
    avg_mood_score DECIMAL,
    consecutive_days INTEGER,
    mood_window_start DATE,
    mood_window_end DATE,
    acknowledged BOOLEAN DEFAULT false,
    resolved BOOLEAN DEFAULT false,
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now(),
    CONSTRAINT unique_active_flag UNIQUE (student_id, resolved)
);

-- 8. FEEDBACK & CONFIG
CREATE TABLE IF NOT EXISTS public.session_feedback (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    appointment_id UUID REFERENCES public.appointments(id),
    student_id UUID REFERENCES public.users(id),
    counsellor_id UUID REFERENCES public.users(id),
    rating INTEGER,
    comment TEXT,
    is_anonymous BOOLEAN DEFAULT false,
    created_at TIMESTAMPTZ DEFAULT now()
);

CREATE TABLE IF NOT EXISTS public.college_config (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    fallback_admin_email TEXT,
    emergency_duty_number TEXT,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- ENABLE REALTIME
ALTER PUBLICATION supabase_realtime ADD TABLE crisis_alerts;
